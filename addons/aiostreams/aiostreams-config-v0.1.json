  "formatter": {
    "id": "custom",
    "definition": {
      "name": "{stream.resolution::exists[\"{stream.resolution::replace('2160p','⭐⭐⭐⭐⭐ 4K UHD')::replace('1440p','⭐⭐⭐⭐☆ 2K QHD')::replace('1080p','⭐⭐⭐☆☆ FHD')::replace('720p','⭐⭐☆☆☆ HD')::replace('576p','⭐☆☆☆☆ SD')::replace('480p','⭐☆☆☆☆ SD')}\"||\"☆☆☆☆☆\"]} - {stream.title::exists[\"{stream.title::title::truncate(30)}\"||\"?\"]}{stream.year::exists[\" ({stream.year})\"||\"\"]}{stream.seasonEpisode::exists[\" ({stream.seasonEpisode::join(' ')::replace('S','Season ')::replace('E','Episode ')})\"||\"\"]}{stream.seadexBest::istrue[\" 🏆\"||\"\"]}{stream.seadex::istrue::and::stream.seadexBest::isfalse[\" 🥈\"||\"\"]}{stream.message::~Download[\"{tools.removeLine}\"||\"\"]}",
      "description": "🎥 {stream.quality::exists[\"{stream.quality::title::replace('Bluray Remux','Lossless BD')::replace('Bluray','Blu-ray')::replace('Web-Dl','Streaming')::replace('Web-dl','Streaming')::replace('Webrip','Web Rip')::replace('Hdrip','HD Rip')::replace('Dvdrip','DVD Rip')::replace('Hdtv','HDTV')::replace('Cam','CAM')::replace('Ts','Telesync')::replace('Tc','Telecine')::replace('Scr','Screener')}\"||\"\"]} {stream.visualTags::exists[\"• {stream.visualTags::join(' ')::replace('DV','Dolby Vision')::replace('HDR10+','HDR10+')::replace('HDR10','HDR10')::replace('HDR','HDR')::replace('10bit','10-bit')}\"||\"\"]} {stream.encode::exists[\"• {stream.encode::replace('HEVC','H.265')::replace('hevc','H.265')::replace('AVC','H.264')::replace('avc','H.264')::replace('x265','H.265')::replace('x264','H.264')}\"||\"\"]} • 🔊 {stream.audioTags::exists[\"{stream.audioTags::join(' ')::replace('Atmos','Dolby Atmos')::replace('TrueHD','Dolby TrueHD')::replace('DTS-HD MA','DTS-MA')::replace('DD+','Dolby Digital+')::replace('DD','Dolby Digital')::replace('EAC3','Dolby Digital+')::replace('AC3','Dolby Digital')}\"||\"Stereo\"]}{stream.audioChannels::exists[\" {stream.audioChannels::join('/')}\"||\"\"]} • ⏱️ {stream.duration::>0[\"{stream.duration::time}\"||\"Unknown\"]}\n💾 {stream.size::>0[\"{stream.size::bytes}\"||\"Unknown\"]} • {service.cached::istrue[\"💎 Cached\"||\"⏳ Not Cached\"]}{stream.type::~debrid[\" (Debrid)\"||\"\"]}{stream.type::~p2p[\" (P2P)\"||\"\"]}{stream.type::~usenet[\" (Usenet)\"||\"\"]} • ☁️ {service.name::exists[\"{service.name}\"||\"Unknown\"]} • {addon.name}{stream.seeders::exists[\" • 👥 {stream.seeders}\"||\"\"]}{stream.age::exists[\" • 📅 {stream.age}\"||\"\"]}\n{stream.uLanguages::exists[\"🗣️ {stream.uLanguageEmojis::join(' ')} • \"||\"\"]}{stream.seasonPack::istrue[\"📦 Pack • \"||\"\"]}{stream.filename::~NF[\"🎬 Netflix • \"||\"\"]}{stream.filename::~DSNP[\"🏰 Disney+ • \"||\"\"]}{stream.filename::~HMAX[\"🟪 HBO Max • \"||\"\"]}{stream.filename::~.MAX.[\"🟪 Max • \"||\"\"]}{stream.filename::~AMZN[\"📦 Amazon • \"||\"\"]}{stream.filename::~APTV[\"🍎 Apple TV+ • \"||\"\"]}{stream.filename::~PMTP[\"⛰️ Paramount+ • \"||\"\"]}{stream.filename::~PCOK[\"🦚 Peacock • \"||\"\"]}{stream.filename::~CRTC[\"🍥 Crunchyroll • \"||\"\"]}{stream.filename::~CR.[\"🍥 Crunchyroll • \"||\"\"]}{stream.releaseGroup::exists[\"👤 {stream.releaseGroup::truncate(10)}\"||\"\"]}{stream.seadexBest::istrue[\" • 🏆 BEST\"||\"\"]}{stream.seadex::istrue::and::stream.seadexBest::isfalse[\" • 🥈 ALT\"||\"\"]}{stream.repack::istrue[\" • 🔄 Repack\"||\"\"]}\n📄 {stream.filename::exists[\"{stream.filename}\"||\"—\"]}"
    }
  },
